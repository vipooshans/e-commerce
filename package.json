{
  "name": "everbuyglobal",
  "version": "1.0.0",
  "description": "EverBuyGlobal - Full-Stack MERN E-Commerce Store",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "seed": "cd server && node utils/seeder.js -i",
    "seed:destroy": "cd server && node utils/seeder.js -d"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
